#!/bin/bash
# ═══════════════════════════════════════════════
# TikFlow.app Launcher v2 — Fenêtre native Swift
# ═══════════════════════════════════════════════
set -e

APP_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
TIKFLOW_DIR="$HOME/Desktop/tiktokpublish/tiktok-automation"
VENV_PYTHON="$TIKFLOW_DIR/venv/bin/python3"
SWIFT_WINDOW="$APP_DIR/Contents/MacOS/TikFlowWindow"

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Nettoyer anciennes instances
lsof -ti:5050 | xargs kill -9 2>/dev/null || true
pkill -9 -f "playwright.*cli.js" 2>/dev/null || true
sleep 1

# Démarrer le serveur Flask
cd "$TIKFLOW_DIR"
"$VENV_PYTHON" app.py > /tmp/tikflow.log 2> /tmp/tikflow.err &
FLASK_PID=$!

# Attendre que le serveur soit prêt
for i in $(seq 1 30); do
    if curl -s --max-time 2 "http://localhost:5050/api/system/status" > /dev/null 2>&1; then
        break
    fi
    sleep 0.3
done

# Ouvrir la fenêtre native Swift
if [ -x "$SWIFT_WINDOW" ]; then
    "$SWIFT_WINDOW" &
    WINDOW_PID=$!
    echo "📱 Fenêtre native TikFlow ouverte"
else
    open "http://localhost:5050"
fi

# Cleanup
cleanup() {
    kill $FLASK_PID 2>/dev/null || true
    kill $WINDOW_PID 2>/dev/null || true
    lsof -ti:5050 | xargs kill -9 2>/dev/null || true
    pkill -9 -f "playwright.*cli.js" 2>/dev/null || true
    exit 0
}
trap cleanup SIGINT SIGTERM EXIT

wait $FLASK_PID 2>/dev/null
